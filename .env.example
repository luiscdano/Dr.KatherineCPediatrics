PORT=8787
HOST=0.0.0.0

# Comma-separated list of allowed origins for CORS.
# Example:
# CORS_ORIGIN=https://drkatherinecpediatrics.com,https://www.drkatherinecpediatrics.com,http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# Absolute or relative path to JSON data store.
DATA_FILE=server/data/submissions.json

# Security and throttling
MAX_BODY_SIZE=100kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Required for admin endpoints
ADMIN_API_KEY=change_me_in_production

# WhatsApp automation bridge to whatsapp-backend service
WHATSAPP_AUTOMATION_ENABLED=false
WHATSAPP_BACKEND_BASE_URL=http://localhost:3000
WHATSAPP_BACKEND_API_KEY=replace_with_internal_api_key
WHATSAPP_CLINIC_RECIPIENT=18095550123
WHATSAPP_REQUEST_TIMEOUT_MS=6000
WHATSAPP_NOTIFY_PARENT_ON_APPOINTMENT=false
