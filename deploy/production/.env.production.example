PORT=8787
HOST=0.0.0.0
TRUST_PROXY=true

# Production origins
CORS_ORIGIN=https://drkatherinecpediatrics.com,https://www.drkatherinecpediatrics.com

MAX_BODY_SIZE=100kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

ADMIN_API_KEY=replace_with_legacy_key_or_disable
ADMIN_DASHBOARD_PASSWORD=replace_with_strong_admin_password
ADMIN_SESSION_SECRET=replace_with_long_random_session_secret
ADMIN_SESSION_TTL_MINUTES=480
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_LOGIN_RATE_LIMIT_MAX=8
ADMIN_SESSION_COOKIE_NAME=drk_admin_session
ADMIN_CSRF_COOKIE_NAME=drk_admin_csrf
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_SAMESITE=strict
ADMIN_COOKIE_DOMAIN=api.drkatherinecpediatrics.com
ADMIN_COOKIE_PATH=/api/v1/admin
ADMIN_ENFORCE_CSRF=true
# Replace with real fixed public IPs/CIDR from admin office/VPN
ADMIN_ALLOWED_IPS=REPLACE_WITH_OFFICE_PUBLIC_IP/32,REPLACE_WITH_DEV_PUBLIC_IP/32

OPS_METRICS_ENABLED=true
OPS_METRICS_KEY=replace_with_ops_key
OPS_HEALTH_URLS=https://api.drkatherinecpediatrics.com/api/v1/health
ALERT_WEBHOOK_URL=replace_with_real_alert_webhook
ALERT_COOLDOWN_MS=300000
LOG_LEVEL=info
LOG_DIR=server/logs

DB_HOST=db
DB_PORT=5432
DB_NAME=dr_katherine
DB_USER=postgres
DB_PASSWORD=replace_with_strong_password
DB_SSL=require
DB_RUN_MIGRATIONS_ON_START=true

WHATSAPP_AUTOMATION_ENABLED=true
WHATSAPP_BACKEND_BASE_URL=http://whatsapp-backend:3000
WHATSAPP_BACKEND_API_KEY=replace_with_internal_api_key
WHATSAPP_CLINIC_RECIPIENT=18095550123
WHATSAPP_REQUEST_TIMEOUT_MS=6000
WHATSAPP_NOTIFY_PARENT_ON_APPOINTMENT=false
