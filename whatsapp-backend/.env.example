NODE_ENV=development
PORT=3000
VERIFY_TOKEN=replace_with_webhook_verify_token
WHATSAPP_TOKEN=replace_with_whatsapp_cloud_api_token
PHONE_NUMBER_ID=replace_with_phone_number_id
META_API_VERSION=v20.0
APP_SECRET=replace_with_meta_app_secret
CORS_ORIGINS=*
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
WEBHOOK_RATE_LIMIT_MAX=300
INTERNAL_API_KEY=replace_with_internal_api_key
DB_PROVIDER=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=whatsapp
